{
  "target": {
    "metric": "strict_recall",
    "recall": 0.80,
    "mode": "emergency_recall"
  },
  "parallelism": {
    "default_workers": 6,
    "fallback_workers": 4,
    "hard_cap_workers": 10
  },
  "runtime_limits": {
    "max_total_runtime_hours": 24,
    "max_iteration_runtime_hours": 3
  },
  "storage_limits": {
    "max_run_dir_gb": 25,
    "min_free_disk_gb": 40,
    "prune_artifacts": "analysis-only"
  },
  "cost_limits": {
    "max_openai_ocr_pages": 10000,
    "max_embedding_calls": 50000,
    "max_llm_analysis_calls": 50
  },
  "quality_limits": {
    "max_best_unknown_predictions": 15000,
    "max_best_known_negative_hits": 50
  },
  "plateau_limits": {
    "min_recall_gain": 0.01,
    "max_plateau_iterations": 3
  }
}
